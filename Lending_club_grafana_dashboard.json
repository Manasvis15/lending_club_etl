          "editorMode": "code",
          "format": "table",
          "rawQuery": true,
          "rawSql": "SELECT \r\n  date_trunc('month', issue_d::timestamp) AS \"time\",\r\n  sum(funded_amnt::numeric) as \"Monthly Funded\",\r\n  (sum(funded_amnt::numeric) - lag(sum(funded_amnt::numeric)) OVER (ORDER BY date_trunc('month', issue_d::timestamp))) \r\n    / NULLIF(lag(sum(funded_amnt::numeric)) OVER (ORDER BY date_trunc('month', issue_d::timestamp)), 0) * 100 as \"Growth %\"\r\nFROM lending_club_loans\r\nGROUP BY 1\r\nORDER BY 1;",
          "refId": "A",
          "sql": {
            "columns": [
              {
                "parameters": [],
                "type": "function"
              }
            ],
